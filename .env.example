# AI provider selection: gemini | openai
# - If AI_PROVIDER is omitted, the app auto-detects based on which API keys are set.
AI_PROVIDER=gemini

# Gemini (Google)
# Prefer setting GOOGLE_API_KEY. GEMINI_API_KEY is also accepted for compatibility.
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional: if you use a proxy/mirror for the Gemini endpoint
# GEMINI_BASE_URL=

# OpenAI / OpenAI-compatible (Chat Completions)
OPENAI_API_KEY=
# Base URL should typically include /v1 (default: https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

